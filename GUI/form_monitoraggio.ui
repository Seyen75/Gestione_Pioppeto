  <property name="styleSheet">
   <string notr="true">/* Sfondo applicato SOLO alla finestra principale della form (Blu Notte Profondo) */
QWidget#form_monitoraggio {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                                      stop:0 #141923, stop:1 #0c0f15);
    color: #ffffff;
}

/* Stile dei contenitori di gruppo */
QGroupBox {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
    margin-top: 15px;
    font-weight: bold;
}

/* Titoli dei GroupBox (Azzurro Ciano Tecnologico) */
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    color: #4fc3f7; /* Azzurro luminoso per staccare dal verde delle altre form */
    padding: 0 5px;
}

QLabel {
    color: #a0aec0; /* Grigio chiaro neutro per le label di descrizione */
    font-size: 13px;
}

/* FORZATURA STRUTTURALE: Stile specifico per la Label dell'Anno */
QGroupBox QLabel#lbl_anno, QLabel#lbl_anno {
    color: #ffffff !important;          /* Bianco puro per massima leggibilità */
    font-size: 22px !important;         /* Molto grande */
    font-weight: bold !important;       /* Grassetto marcato */
    font-family: &quot;Courier New&quot;, monospace !important; 
}

/* FORZATURA STRUTTURALE: Stile specifico per la Label della Stagione */
QGroupBox QLabel#lbl_stagione, QLabel#lbl_stagione {
    color: #00e5ff !important;          /* Azzurro Ciano Neon ad alta visibilità */
    font-size: 18px !important;         /* Evidente */
    font-weight: bold !important;       /* Grassetto */
    font-family: &quot;Courier New&quot;, monospace !important;
    padding-left: 5px;
}

/* Pulsante Standard / Avanzamento Temporale (Azzurro di Comando) */
QPushButton {
    background-color: #0288d1;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    min-height: 30px;
    padding: 6px 12px;
}

QPushButton:hover {
    background-color: #039be5;
}

QPushButton:pressed {
    background-color: #01579b;
}

/* Variante per il Pulsante di Chiusura/Termina Sessione (Rosso Corallo) */
/* Nota: applicheremo questo objectName specifico nel Designer al tasto di interruzione */
QPushButton#btn_termina_sessione {
    background-color: #d32f2f;
}

QPushButton#btn_termina_sessione:hover {
    background-color: #f44336;
}

QPushButton#btn_termina_sessione:pressed {
    background-color: #b71c1c;
}

/* Stile della Tabella Monitoraggio Lotti */
QTableWidget {
    background-color: #171e2c;       /* Sfondo celle coordinato col blu notte */
    gridline-color: #2b364a;         /* Quadretti di separazione blu scuro */
    color: #ffffff;
    font-size: 13px;
    border: 1px solid #2b364a;
}

/* Stile dei titoli delle colonne in alto */
QHeaderView::section {
    background-color: #222c3e;       /* Sfondo dei titoli di colonna */
    color: #8ab4f8;                  /* Testo dei titoli in azzurro soft */
    padding: 6px;
    font-weight: bold;
    border: 1px solid #2b364a;
}

/* Stile della riga selezionata (Evidenziazione Blu Cobalto) */
QTableWidget::item:selected {
    background-color: #1a5ab5;       
    color: #ffffff;
}</string>
