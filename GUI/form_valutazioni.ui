  <property name="styleSheet">
   <string notr="true">/* SFONDO DELLA FINESTRA E DEI PANNELLI*/

QWidget#FormValutazioni, QTabWidget::pane {
    background-color: #1a1516;  /* Antracite */
}

/* Stile radicale delle Tab (Ancoraggio forzato a sinistra) */
QTabWidget::tab-bar {
    left: 0px;
}

QTabBar {
    alignment: left;
    background: transparent;
}

/* Impostazione delle schede delle tab */
QTabBar::tab {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #2a1f21, stop:1 #1f1618);
	/* Grigio-rosa morbido per il testo inattivo */    
	color: #b0a2a4; 
    border: 1px solid #3d292c;
	/* bordo lateriale*/
    border-bottom: none;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    padding: 8px 20px; 
    font-weight: bold;
    font-size: 11px;
    width: 200px; 
}

/* Tab Attivo */
QTabBar::tab:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #8a1c24, stop:1 #4f0e13);
    color: #ffffff;
    border: 1px solid #a8222d;
    border-bottom: 1px solid #1a1516;
}

/* Tab con mouse che passa sopra */
QTabBar::tab:hover:!selected {
    background: #362528;
    color: #ffffff;
}

/* QLabel - Tutto in Rosso Corallo Chiaro*/
#FormValutazioni QLabel, 
QGroupBox QLabel, 
QTabWidget QLabel, 
QLabel {
    color: #ff8a80 !important;
    font-size: 11px;
    font-weight: normal;
    background: transparent;
}

/* Label dei GroupBox e dei controlli base  */
QLabel#lbl_anno_selezionato,
QLabel#lbl_anno_selezionato_2,
QLabel#lbl_titolo_lotto, 
QGroupBox {
    font-weight: bold !important;
    font-size: 11px !important;
}

/* Label interne al GroupBox Rese Totali  */
QLabel#lbl_tot_3,
QLabel#lbl_tot_4,
QLabel#lbl_tot_5,
QLabel#lbl_tot_6,
QLabel#lbl_tot_7,
QLabel#lbl_tot_8,
QLabel#lbl_tot_9 {
    font-size: 13px;
    color: #ffecb3
}


QGroupBox#GroupBoxReseTotali {
	color: #ff8a80 !important;
    font-size: 16px;
    font-weight: normal;
    background: transparent;
}

QLabel#lbl_tipo_filiera_lotto {
    color: #ffca28 !important;        
    font-size: 16px !important;        
    font-weight: bold !important;     
    font-family: &quot;Georgia&quot;, serif;     
    padding-top: 10px;              
    padding-bottom: 5px;             
    background: transparent;
}

QGroupBox#groupBox_6 {
    border: 1px solid #4a282d;
    border-radius: 6px;
    margin-top: 15px;
    background-color: #1c1415;
    color: #ff8a80; 
}

/* GroupBox6 */
QGroupBox#groupBox_6::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
    left: 10px;
    color: #ff8a80; /* Rosso Corallo come definito per le label */
}

/* QTableWidget - Sintonizzate sui toni caldi */
QTableWidget {
    background-color: #151011; 
    gridline-color: #2b1d20;
    color: #ffffff;
    border: 1px solid #3d2429;
    border-radius: 6px;
    font-size: 11px;
}

QTableWidget::item {
    padding: 6px;
}

QTableWidget::item:selected {
    background-color: #5a151a;
    color: #ffffff;
}

/* Testo dei titoli delle colonne  */
QHeaderView::section {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #2d181b, stop:1 #1f1012);
    color: #ff8a80;
    padding: 6px;
    border: 1px solid #3d2429;
    font-weight: bold;
    font-size: 11px;
}

/* Pulsanti */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #7d1820, stop:1 #420f13);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    min-height: 30px;
    padding: 6px 12px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #9a2630, stop:1 #5e161b);
}

/* Pulsante premuto*/
QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #5e161b, stop:1 #2a0a0c);
}

/* GROUPBOX INFORMATIVI */
QGroupBox {
    border: 1px solid #4a282d;
    border-radius: 6px;
    margin-top: 15px;
    background-color: #1c1415;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
    left: 10px;
}

/* QComboBox presenti nelle Tab */
QComboBox { 
                    background-color: #2d181b; 
                    color: #ffffff; 
                    border: 1px solid #3d2429; 
                    border-radius: 4px; 
                    padding: 4px 10px;
                }
                QComboBox::drop-down {
                    subcontrol-origin: padding;
                    subcontrol-position: top right;
                    width: 20px;
                    border-left-width: 1px;
                    border-left-color: #3d2429;
                    border-left-style: solid;
                }
                QComboBox QAbstractItemView {
                    background-color: #151011;
                    color: #ffffff;
                    selection-background-color: #5a151a;
                    border: 1px solid #3d2429;
                }
 
</string>
