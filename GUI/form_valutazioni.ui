   <string notr="true">/* SFONDO DELLA FINESTRA E DEI PANNELLI (Nuovo tono caldo armonizzato) */

QWidget#FormValutazioni, QTabWidget::pane {
    background-color: #1a1516;  /* Antracite */
}

/* STILE RADICALE DELLE LINGUETTE (Ancoraggio forzato a sinistra) */
QTabWidget::tab-bar {
    left: 0px;
}

QTabBar {
    alignment: left;
    background: transparent;
}

QTabBar::tab {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #2a1f21, stop:1 #1f1618);
    color: #b0a2a4; /* Grigio-rosa morbido per il testo inattivo */
    border: 1px solid #3d292c;
    border-bottom: none;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    padding: 8px 20px; 
    font-weight: bold;
    font-size: 11px;
    
    /* Usiamo width fisso anziché min-width per impedire a Qt qualsiasi ricalcolo */
    width: 200px; 
}

/* Tab Attivo (Selezionato) */
QTabBar::tab:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #8a1c24, stop:1 #4f0e13);
    color: #ffffff;
    border: 1px solid #a8222d;
    border-bottom: 1px solid #1a1516; /* Si fonde con il nuovo sfondo caldo */
}

QTabBar::tab:hover:!selected {
    background: #362528;
    color: #ffffff;
}

/* =========================================================================
   ETICHETTE TESTUALI (QLabel - Tutto in Rosso Corallo Chiaro)
   ========================================================================= */
#FormValutazioni QLabel, 
QGroupBox QLabel, 
QTabWidget QLabel, 
QLabel {
    color: #ff8a80 !important;
    font-size: 11px;
    font-weight: normal;
    background: transparent;
}

QLabel#lbl_anno_selezionato,
QLabel#lbl_anno_selezionato_2,
QLabel#lbl_titolo_lotto, 
QGroupBox {
    font-weight: bold !important;
    font-size: 11px !important;
}

/* ---Label interne al GroupBox Rese Totali --- */
QLabel#lbl_tot_3,
QLabel#lbl_tot_4,
QLabel#lbl_tot_5,
QLabel#lbl_tot_6,
QLabel#lbl_tot_7,
QLabel#lbl_tot_8,
QLabel#lbl_tot_9 {
    font-size: 13px;
    color: #ffecb3
}

QGroupBox#GroupBoxReseTotali {
	color: #ff8a80 !important;
    font-size: 16px;
    font-weight: normal;
    background: transparent;
}

QLabel#lbl_tipo_filiera_lotto {
    color: #ffca28 !important;         /* Un bellissimo Giallo Ambra/Oro luminoso */
    font-size: 16px !important;        /* Dimensione maggiorata per dominare la tabella */
    font-weight: bold !important;      /* Grassetto marcato */
    font-family: &quot;Georgia&quot;, serif;     /* Font elegante coerente con il titolo main */
    padding-top: 10px;                 /* Distanza dal selettore sopra */
    padding-bottom: 5px;               /* Distanza dalla tabella sotto */
    background: transparent;
}

/* =========================================================================
   TABELLE (QTableWidget) - Sintonizzate sui toni caldi
   ========================================================================= */
QTableWidget {
    background-color: #151011; /* Celle scure calde */
    gridline-color: #2b1d20;
    color: #ffffff;
    border: 1px solid #3d2429;
    border-radius: 6px;
    font-size: 11px;
}

QTableWidget::item {
    padding: 6px;
}

QTableWidget::item:selected {
    background-color: #5a151a;
    color: #ffffff;
}

QHeaderView::section {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #2d181b, stop:1 #1f1012);
    color: #ff8a80;
    padding: 6px;
    border: 1px solid #3d2429;
    font-weight: bold;
    font-size: 11px;
}

/* =========================================================================
   PULSANTI GENERALI E DI USCITA
   ========================================================================= */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #7d1820, stop:1 #420f13);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    min-height: 30px;
    padding: 6px 12px;
}


/* =========================================================================
   GROUPBOX INFORMATIVI
   ========================================================================= */
QGroupBox {
    border: 1px solid #4a282d;
    border-radius: 6px;
    margin-top: 15px;
    background-color: #1c1415;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
    left: 10px;
}

QComboBox { 
                    background-color: #2d181b; 
                    color: #ffffff; 
                    border: 1px solid #3d2429; 
                    border-radius: 4px; 
                    padding: 4px 10px;
                }
                QComboBox::drop-down {
                    subcontrol-origin: padding;
                    subcontrol-position: top right;
                    width: 20px;
                    border-left-width: 1px;
                    border-left-color: #3d2429;
                    border-left-style: solid;
                }
                QComboBox QAbstractItemView {
                    background-color: #151011;
                    color: #ffffff;
                    selection-background-color: #5a151a;
                    border: 1px solid #3d2429;
                }
 
QSlider::groove:horizontal { 
                    background: #2d181b; 
                    height: 6px; 
                    border-radius: 3px; 
                } 
                QSlider::handle:horizontal { 
                    background: #ff8a80; 
                    width: 14px; 
                    margin: -4px 0; 
                    border-radius: 7px; 
                }</string>
