   <property name="styleSheet">
    <string notr="true">#centralwidget {
    border-image: url(:/sfondo_main.jpg) 0 0 0 0 stretch stretch;
}

/* Stile elegante per tutti i pulsanti dell'interfaccia */
QPushButton {
background-color: rgba(26, 42, 58, 0.85); /* Blu scuro semi-trasparente */
    color: white;                             /* Testo bianco */
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
}

/* Effetto quando si passa sopra con il mouse (Hover) */
QPushButton:hover {
    background-color: qlineargradient(
        x1: 0, y1: 0, 
        x2: 0, y2: 1,
        stop: 0 rgba(215, 235, 255, 0.9),  /* Azzurro chiarissimo e cristallino in alto */
        stop: 1 rgba(175, 210, 245, 0.9)   /* Azzurro pastello leggermente più profondo in basso */
    );
    border: 1px solid #0078d4;               /* Bordino azzurro istituzionale che definisce i contorni */
    color: #1a2a3a;
}

/* Effetto quando il pulsante viene cliccato */
QPushButton:pressed {
    background-color: rgba(230, 230, 230, 0.9);
}

/* Stile specifico per il tasto Esci */
QPushButton#btn_esci, QPushButton[text=&quot;Esci&quot;] {
    background-color: rgba(217, 83, 79, 0.85);
    color: white;
    border: 1px solid rgba(217, 83, 79, 0.5);
}

QPushButton#btn_esci:hover, QPushButton[text=&quot;Esci&quot;]:hover {
    background-color: rgba(217, 83, 79, 1.0);
}

QLabel#label_titolo {
    font-family: &quot;Georgia&quot;, &quot;Times New Roman&quot;, serif; /* Un font elegante con le grazie come nella bozza */
    background: transparent;
    padding: 10px;
}

/* --- STATO DISABILITATO PER TUTTI I PULSANTI --- */
QPushButton:disabled {
    background-color: rgba(40, 50, 60, 0.4);   /* Grigio-blu molto scuro e quasi trasparente */
    color: rgba(255, 255, 255, 0.3);          /* Testo bianco fortemente opacizzato (spento) */
    border: 1px solid rgba(255, 255, 255, 0.1);/* Bordino quasi invisibile */
}

/* IMPORTANTE: Disattiviamo l'effetto hover quando il tasto è bloccato */
QPushButton:disabled:hover {
    background-color: rgba(40, 50, 60, 0.4);   /* Resta identico allo stato disabled */
    border: 1px solid rgba(255, 255, 255, 0.1);/* Nessun cambio di bordo */
    color: rgba(255, 255, 255, 0.3);          /* Il testo non si illumina */
}

QLabel {
    color: #b0bec5;
    font-size: 10px;
    font-style: italic;
    padding: 5px;
}</string>
