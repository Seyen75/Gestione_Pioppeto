  <property name="styleSheet">
   <string notr="true">/* Sfondo applicato SOLO alla finestra principale della form */
QWidget#FormLotti {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                                      stop:0 #1e2622, stop:1 #121715);
    color: #ffffff;
}

/* Stile dei contenitori di gruppo */
QGroupBox {
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    margin-top: 15px;
    font-weight: bold;
}

/* Titoli dei GroupBox */
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    color: #8cbfa4; /* Verde salvia chiaro coordinato */
    padding: 0 5px;
}

/* Campi numerici di inserimento */
QSpinBox {
    background-color: #2a332f;
    border: 1px solid #44544c;
    border-radius: 4px;
    padding: 4px;
    color: #ffffff;
    min-width: 65px;
}

/* Evidenziazione del campo quando l'utente ci clicca dentro */
QSpinBox:focus {
    border: 1px solid #8cbfa4;
    background-color: #313c37;
}

/* Etichette di testo statiche dentro la form */
QLabel {
    color: #e0e0e0;
}

/* Pulsante di salvataggio finale */
QPushButton {
    background-color: #347a50;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    min-height: 30px;
    padding: 4px
}

/* Effetto al passaggio del mouse sul pulsante */
QPushButton:hover {
    background-color: #419663;
}

/* Effetto al click sul pulsante */
QPushButton:pressed {
    background-color: #245939;
}

QTableWidget {
                    background-color: #1e2422;      /* Sfondo delle celle leggermente più chiaro dello sfondo app */
                    gridline-color: #3a4743;          /* Il colore dei quadretti di separazione */
                    color: #ffffff;                  /* Colore del testo delle celle */
                    font-size: 13px;
                    border: 1px solid #3a4743;
                }
                
                /* Stile dei titoli delle colonne in alto */
                QHeaderView::section {
                    background-color: #2d3835;       /* Sfondo dei titoli */
                    color: #a3b8b0;                  /* Testo dei titoli (verde oliva chiaro/grigio) */
                    padding: 6px;
                    font-weight: bold;
                    border: 1px solid #3a4743;       /* Confine dei titoli per allinearsi alla griglia */
                }
                
                /* Stile quando l'utente seleziona una riga */
                QTableWidget::item:selected {
                    background-color: #2e6b4e;       /* Colore verde foresta per la riga selezionata */
                    color: #ffffff;                  /* Testo bianco sulla selezione */
                }
</string>
